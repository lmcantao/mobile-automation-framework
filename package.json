{
  "name": "mobile-automation-framework",
  "version": "1.0.0",
  "description": "Mobile automation framework using WebdriverIO, Appium and Mocha.",
  "private": true,
  "scripts": {
    "test:android": "wdio run ./config/wdio.android.conf.js",
    "test:android:smoke": "wdio run ./config/wdio.smoke.conf.js",
    "test:android:login": "wdio run ./config/wdio.login.conf.js",
    "test:android:forms": "wdio run ./config/wdio.forms.conf.js",
    "test:android:navigation": "wdio run ./config/wdio.navigation.conf.js",
    "test:android:gestures": "wdio run ./config/wdio.gestures.conf.js",
    "test:android:interactions": "wdio run ./config/wdio.interactions.conf.js",
    "test:ios": "wdio run ./config/wdio.ios.conf.js",
    "test:browserstack": "wdio run ./config/wdio.browserstack.conf.js",
    "allure:report": "allure generate allure-results -o allure-report --clean",
    "allure:serve": "allure serve reports/allure-results"
  },
  "author": "Lawrense Cantão",
  "license": "MIT",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.29.1",
    "@wdio/appium-service": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "allure-commandline": "^2.43.0",
    "appium": "^3.5.2",
    "appium-uiautomator2-driver": "^8.1.0"
  }
}
